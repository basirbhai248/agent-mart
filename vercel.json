{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/subscription/charge",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/payouts/retry",
      "schedule": "0 7 * * *"
    }
  ]
}
